VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Optional: published CSV URL (e.g. Google Sheets → Publish to web → CSV). Else uses /user-profile-sheet.csv in public/.
# VITE_USER_PROFILE_SHEET_URL=

# `npm run dev:ngrok`: token from https://dashboard.ngrok.com/get-started/your-authtoken
# Optional if you already ran `ngrok config add-authtoken` globally.
# NGROK_AUTHTOKEN=

# Leave unset for same-origin /api (Vite proxies to the AI server). Required for ngrok/mobile.
# Set only if frontend and API use different hosts, e.g. VITE_AI_PROXY_URL=https://other.ngrok-free.app
# VITE_AI_PROXY_URL=

# Local AI proxy config (Ollama)
AI_PROXY_PORT=8787
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Cloud (needs `ollama signin`): gpt-oss:120b-cloud — local CPU: e.g. gemma2:2b
OLLAMA_MODEL=gpt-oss:120b-cloud
# Per-request ceiling to Ollama (ms). CPU + large prompts: try 300000–600000 if you see 504 aborted.
OLLAMA_TIMEOUT_MS=300000
OLLAMA_NUM_CTX=1536
OLLAMA_NUM_PREDICT_DEFAULT=512

# CPU-friendly fast mode for Life Manager orchestration
VITE_LIFEMANAGER_FAST_MODE=true
# How many specialist agents run at once in fast mode (1–5). Default 2 balances speed vs load.
VITE_LIFEMANAGER_FAST_CONCURRENCY=2
